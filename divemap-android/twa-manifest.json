    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "orientation": "any",
  "fingerprints": [],
  "additionalTrustedOrigins": [],
  "retainedBundles": [],
  "protocolHandlers": [
    {
      "protocol": "web+divemap",
      "url": "https://divemap.gr/dive-sites?q=%s"
    }
  ],
  "fileHandlers": [],
  "launchHandlerClientMode": [
    "navigate-existing",
    "auto"
  ],
  "displayOverride": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "appVersion": "1.0.1"
